# Local .terraform folder (contains binaries and modules)
**/.terraform/*

# .tfstate files (Contains sensitive data and infrastructure secrets)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (which often contain secrets)
*.tfvars
*.tfvars.json

# Exclude override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Exclude Venv
venv/
ENV/
ansible-venv/
.ansible-venv/

# Exclude Ansible Variables
**/n8n.yml
**/group_variables/
**/host_vars/